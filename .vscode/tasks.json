{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "${workspaceFolder}/make.ps1",
            "args": ["all"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "${workspaceFolder}/make.ps1",
            "args": ["run"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": ["Build"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "${workspaceFolder}/make.ps1",
            "args": ["clean"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
